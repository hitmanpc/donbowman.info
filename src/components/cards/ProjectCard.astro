---
interface Props {
  title: string;
  description: string;
  tech: string[];
  href: string;
}

const { title, description, tech, href } = Astro.props;
---

<a href={href} class="block border border-slate-200/[0.14] bg-slate-900/[0.72] rounded-3xl p-7 no-underline transition-all duration-150 hover:-translate-y-1 hover:border-blue-300/50 hover:bg-slate-900/[0.92]">
  <h3 class="text-white text-[1.35rem] m-0 mb-3">{title}</h3>

  <p class="text-slate-300 leading-[1.7] m-0 mb-5">{description}</p>

  <div class="flex gap-2.5 flex-wrap">
    {tech.map((item) => <span class="border border-blue-300/25 bg-blue-500/[0.12] text-blue-200 rounded-full px-3 py-2 text-sm font-bold">{item}</span>)}
  </div>
</a>