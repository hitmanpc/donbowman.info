---
import { site } from "../../data/site";
---

<section class="py-20 pb-30">
  <h2 class="text-white text-3xl md:text-4xl lg:text-5xl leading-tight m-0">Looking for a senior engineer who can move across the stack?</h2>

  <p class="max-w-3xl text-slate-300 leading-relaxed text-lg">
    I bring experience in frontend engineering, backend APIs, architecture,
    CI/CD, mentoring, and real-world problem solving.
  </p>

  <div class="flex gap-3.5 flex-wrap max-sm:*:w-full">
    <a href={`mailto:${site.email}`} class="inline-flex items-center justify-center min-h-11 px-4.5 rounded-full no-underline font-bold transition-all duration-150 hover:-translate-y-0.5 bg-blue-500 text-white">Contact Me</a>
    <a href={site.resumeUrl} class="inline-flex items-center justify-center min-h-11 px-4.5 rounded-full no-underline font-bold transition-all duration-150 hover:-translate-y-0.5 border border-slate-400/30 text-gray-200">View Resume</a>
  </div>
</section>