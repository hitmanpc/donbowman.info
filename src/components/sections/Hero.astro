---
import { site } from "../../data/site";
---

<section class="grid lg:grid-cols-[1.4fr_0.6fr] items-center gap-12 py-16 max-md:grid-cols-1 max-md:text-center max-sm:pt-16">
  <div>
    <p class="text-blue-300 text-sm font-bold tracking-[0.12em] uppercase mb-4">{site.status}</p>

    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] m-0 text-white">{site.name}</h1>

    <h2 class="text-2xl sm:text-3xl md:text-4xl leading-tight my-4 text-slate-300 font-bold">
      {site.title}
    </h2>

    <p class="text-xl sm:text-2xl md:text-3xl text-blue-200 mt-6 mb-2 font-bold">
      {site.tagline}
    </p>

    <p class="max-w-3xl text-lg leading-relaxed text-slate-300 mb-8">
      {site.description}
    </p>

    <div class="flex gap-3.5 flex-wrap max-sm:*:w-full">
      <a href="#projects" class="inline-flex items-center justify-center min-h-11 px-4.5 rounded-full no-underline font-bold transition-all duration-150 hover:-translate-y-0.5 bg-blue-500 text-white">View Projects</a>
      <a href={site.resumeUrl} class="inline-flex items-center justify-center min-h-11 px-4.5 rounded-full no-underline font-bold transition-all duration-150 hover:-translate-y-0.5 border border-slate-400/30 text-gray-200">Download Resume</a>
      <a href={`mailto:${site.email}`} class="inline-flex items-center justify-center min-h-11 px-4.5 rounded-full no-underline font-bold transition-all duration-150 hover:-translate-y-0.5 border border-slate-400/30 text-gray-200">Contact Me</a>
    </div>
  </div>
  
  <img
    src="/headshot.png"
    alt="Don Bowman professional headshot"
    width="320"
    height="320"
    loading="eager"
    class="w-70 h-70 object-cover rounded-full shadow-[0_20px_45px_rgba(15,23,42,0.18)] max-md:mx-auto max-md:w-55 max-md:h-55"
  />
</section>