---
import { getCollection } from "astro:content";
import ProjectCard from "../cards/ProjectCard.astro";

const projects = await getCollection("projects", ({ data }: { data: any }) => {
  return data.featured === true;
});

const featuredProjects = projects.sort(
  (a: { data: { order: number; }; }, b: { data: { order: number; }; }) => a.data.order - b.data.order
);
---

<section class="py-18 border-t border-slate-200/[0.12]" id="projects">
  <div class="max-w-3xl mb-7">
    <p class="text-blue-300 text-sm font-bold tracking-[0.12em] uppercase mb-4">Featured work</p>
    <h2 class="text-white text-3xl md:text-4xl lg:text-5xl leading-tight m-0">Projects and case studies</h2>
  </div>

  <div class="grid grid-cols-2 gap-5 max-lg:grid-cols-1">
    {
      featuredProjects.map((project: { data: { title: string; description: string; tech: string[]; }; id: any; }) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          tech={project.data.tech}
          href={`/projects/${project.id}`}
        />
      ))
    }
  </div>
</section>